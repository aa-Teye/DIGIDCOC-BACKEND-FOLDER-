# Defaults to a local SQLite file (sqlite:///./digidoc.db) if unset. Point this at
# a Supabase/Neon Postgres connection string when ready — install psycopg[binary]
# first (see requirements.txt), no code change needed.
# DATABASE_URL=postgresql://user:password@localhost:5432/digidoc

JWT_SECRET=change-me

# Seeded on first startup if no user with this email exists yet.
SEED_ADMIN_EMAIL=admin@digidoc.app
SEED_ADMIN_PASSWORD=DigiDocAdmin123!

PAYSTACK_SECRET_KEY=

# Auto-populates a patient's first Records/Family/Messaging/Activity/Billing
# fetch with sample data so demos and local dev don't show empty screens.
# Set to "false" before real launch — real patients should start empty.
SEED_DEMO_DATA=true
